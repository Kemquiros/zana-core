{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZANA",
  "version": "2.8.8",
  "identifier": "com.vecanova.zana",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:54448",
    "beforeDevCommand": "npm run dev -- --port 54448",
    "beforeBuildCommand": "TAURI=1 npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ZANA — Aeon Cognitivo",
        "width": 420,
        "height": 820,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "center": true,
        "visible": true
      }
    ],
    "trayIcon": {
      "id": "zana-tray",
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "title": "ZANA"
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws://localhost:54446 http://localhost:54446 http://localhost:51111 http://localhost:51112; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/zana_steel_core.so",
      "resources/zana_audio_dsp.so",
      "resources/zana_armor.so"
    ],
    "externalBin": ["sidecar/zana-gateway"],
    "linux": {
      "appimage": { "bundleMediaFramework": true },
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libayatana-appindicator3-1"],
        "desktopTemplate": "resources/zana.desktop",
        "postInstallScript": "scripts/postinst.sh"
      }
    }
  },
  "plugins": {}
}
