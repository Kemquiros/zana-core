# ═══════════════════════════════════════════════════════════
#  XANA Core — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════

# ── API Keys ─────────────────────────────────────────────────
# LiteLLM routes automatically to the provider based on the model prefix.
ANTHROPIC_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
GROQ_API_KEY=your_key_here
OPENROUTER_API_KEY=your_key_here

# ── Database Credentials ─────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password
NEO4J_PASSWORD=change_me_strong_password

# ── LLM Models (provider-agnostic via LiteLLM) ───────────────
# Format: "provider/model-name"
# Examples: "openai/gpt-4o", "anthropic/claude-3-5-sonnet", "gemini/gemini-1.5-pro", "ollama/llama3"
XANA_PRIMARY_MODEL=anthropic/claude-3-5-haiku-20241022
XANA_VISION_MODEL=anthropic/claude-3-5-sonnet-20241022

# ── Host-exposed Ports ───────────────────────────────────────
XANA_GATEWAY_PORT=54446
XANA_PWA_PORT=54448
XANA_CHROMA_PORT=58001
XANA_POSTGRES_PORT=55433
XANA_REDIS_PORT=56380
XANA_NEO4J_HTTP_PORT=57474
XANA_NEO4J_BOLT_PORT=57687

# ── Internal Docker Hostnames (do not change unless multi-host) ──
XANA_GATEWAY_HOST=gateway
XANA_PWA_HOST=pwa

# ── Database Connection ──────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=55433
POSTGRES_DB=xana
POSTGRES_USER=xana
CHROMA_HOST=localhost
CHROMA_PORT=58001
NEO4J_URI=bolt://localhost:57687
NEO4J_USER=neo4j

# ── Memory & Embeddings ──────────────────────────────────────
# Absolute path to your Obsidian vault (optional — used by Memory MCP)
VAULT_PATH=/path/to/your/obsidian/vault
EMBED_MODEL=all-MiniLM-L6-v2

# ── Node Identity ────────────────────────────────────────────
XANA_NODE_ID=AEON-001
XANA_PUBLIC_URL=http://localhost:54446
# Branding shown in the A2A AgentCard (your name or organization)
XANA_PROVIDER_NAME=XANA
# Your public domain if self-hosting (e.g., https://xana.yourdomain.com)
XANA_PROVIDER_URL=https://your-domain.example.com

# ── External Services ────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
SYMBIOSIS_URL=http://localhost:4444

# ── Public Domain (Caddy reverse-proxy) ─────────────────────
# Examples: ":80"  |  "xana.yourdomain.com"  |  "xana.local"
XANA_DOMAIN=:80
