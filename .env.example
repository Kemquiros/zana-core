# ═══════════════════════════════════════════════════════════
#  ZANA Core — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════

# ── API Keys ─────────────────────────────────────────────────
# LiteLLM routes automatically to the provider based on the model prefix.
ANTHROPIC_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
GROQ_API_KEY=your_key_here
OPENROUTER_API_KEY=your_key_here

# ── Database Credentials ─────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password
NEO4J_PASSWORD=change_me_strong_password

# ── LLM Models (provider-agnostic via LiteLLM) ───────────────
# Format: "provider/model-name"
# Examples: "openai/gpt-4o", "anthropic/claude-3-5-sonnet", "gemini/gemini-1.5-pro", "ollama/llama3"
ZANA_PRIMARY_MODEL=anthropic/claude-3-5-haiku-20241022
ZANA_VISION_MODEL=anthropic/claude-3-5-sonnet-20241022

# ── Host-exposed Ports ───────────────────────────────────────
ZANA_GATEWAY_PORT=54446
ZANA_PWA_PORT=54448
ZANA_CHROMA_PORT=58001
ZANA_POSTGRES_PORT=55433
ZANA_REDIS_PORT=56380
ZANA_NEO4J_HTTP_PORT=57474
ZANA_NEO4J_BOLT_PORT=57687

# ── Internal Docker Hostnames (do not change unless multi-host) ──
ZANA_GATEWAY_HOST=gateway
ZANA_PWA_HOST=aria-ui

# ── Database Connection ──────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=55433
POSTGRES_DB=zana
POSTGRES_USER=zana
CHROMA_HOST=localhost
CHROMA_PORT=58001
NEO4J_URI=bolt://localhost:57687
NEO4J_USER=neo4j

# ── Memory & Embeddings ──────────────────────────────────────
# Absolute path to your Obsidian vault (optional — used by Memory MCP)
VAULT_PATH=/path/to/your/obsidian/vault
EMBED_MODEL=all-MiniLM-L6-v2

# ── Node Identity ────────────────────────────────────────────
ZANA_NODE_ID=AEON-001
ZANA_PUBLIC_URL=http://localhost:54446
# Branding shown in the A2A AgentCard (your name or organization)
ZANA_PROVIDER_NAME=ZANA
# Your public domain if self-hosting (e.g., https://zana.yourdomain.com)
ZANA_PROVIDER_URL=https://your-domain.example.com

# ── External Services ────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
SYMBIOSIS_URL=http://localhost:4444

# ── Public Domain (Caddy reverse-proxy) ─────────────────────
# Examples: ":80"  |  "zana.yourdomain.com"  |  "zana.local"
ZANA_DOMAIN=:80

# ── Telegram Bot ─────────────────────────────────────────────
# 1. Create a bot via @BotFather on Telegram
# 2. Paste the token here
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Comma-separated Telegram user IDs allowed to use the bot (leave empty = public)
ZANA_TELEGRAM_ALLOWED_USERS=
# Production: set your HTTPS domain for webhook mode
# Leave empty to use long-polling (development)
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# ── Slack Bot ─────────────────────────────────────────────────
# 1. Create app at api.slack.com/apps → OAuth & Permissions → Bot Token Scopes:
#    channels:history, channels:read, chat:write, commands, app_mentions:read, im:history
# 2. Enable Socket Mode → App-Level Tokens → connections:write
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
ZANA_SLACK_DEFAULT_CHANNEL=general
# Optional: comma-separated Slack user IDs allowed to use /zana (empty = all)
ZANA_SLACK_ALLOWED_USERS=

# ── Discord Bot ───────────────────────────────────────────────
# 1. Create app at discord.com/developers/applications → Bot → Reset Token
# 2. Enable: MESSAGE CONTENT INTENT, SERVER MEMBERS INTENT
# 3. Invite with scopes: bot, applications.commands
DISCORD_BOT_TOKEN=your-discord-bot-token
# Optional: guild ID for instant slash command sync (leave empty for global sync)
DISCORD_GUILD_ID=
# Optional: comma-separated Discord user IDs allowed (empty = public)
ZANA_DISCORD_ALLOWED=

# ── Ollama (local LLM — plug&play) ───────────────────────────
# Start Ollama: ollama serve
# Pull a model: ollama pull llama3.1:8b
# Then set: ZANA_PRIMARY_MODEL=ollama/llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
